# Public application configuration
NEXT_PUBLIC_APP_URL=https://en.igihe.com
NEXT_PUBLIC_WORDPRESS_API_URL=https://example.com/wp-json/wp/v2

# Server-only integration credentials
REVALIDATION_SECRET=replace-me
ARTICLE_REFRESH_SECRET=replace-me
HEALTH_CHECK_SECRET=replace-me
# Local AI server base URL (e.g. http://igihe.local or http://192.168.x.x)
NEWS_AI_API_URL=http://igihe.local

# Ask-IGIHE article ingestion webhook (set to trigger AI DB sync on new articles)
# ASK_IGIHE_WEBHOOK_URL=http://igihe.local:8000/api/v1/sources/wp-webhook
# ASK_IGIHE_WEBHOOK_SECRET=your-wp-webhook-secret-here

# Local disposable cache limit (default: 536870912 / 512 MB)
FILE_CACHE_MAX_BYTES=536870912
# Enable verbose cache hit/set logs only while debugging
FILE_CACHE_DEBUG=false
